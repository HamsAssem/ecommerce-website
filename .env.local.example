# ─────────────────────────────────────────────────────────
# Supabase (Project Settings -> API)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-side only, keep secret

# ─────────────────────────────────────────────────────────
# Paymob (Egypt) — https://accept.paymob.com
# ─────────────────────────────────────────────────────────
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_CARD=0000000         # integration id for Online Card
PAYMOB_INTEGRATION_WALLET=0000000       # integration id for Mobile Wallet
PAYMOB_IFRAME_ID=000000                 # iframe id for card checkout
PAYMOB_HMAC_SECRET=your_hmac_secret     # HMAC secret to verify callbacks

# Site URL (used by callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
